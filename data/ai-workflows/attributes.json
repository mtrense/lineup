          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "discovery", "value": "Discovery", "color": "cyan" },
              { "id": "spec", "value": "Spec", "color": "blue" },
              { "id": "architecture", "value": "Architecture", "color": "purple" },
              { "id": "planning", "value": "Planning", "color": "blue" },
              { "id": "tasks", "value": "Tasks", "color": "green" },
              { "id": "implementation", "value": "Implementation", "color": "green" },
              { "id": "review", "value": "Review", "color": "orange" },
              { "id": "testing", "value": "Testing", "color": "yellow" },
              { "id": "deployment", "value": "Deployment", "color": "red" },
              { "id": "retrospective", "value": "Retrospective", "color": "gray" }
