{
  "name": "AI-Assisted Development Workflows",
  "description": "Frameworks and toolchains that structure AI coding agents through software development work, from spec-driven methodologies to multi-agent orchestration",
  "groups": [
    {
      "id": "general",
      "name": "General Information",
      "description": "Basic information about the framework",
      "expandedByDefault": true,
      "attributes": [
        {
          "id": "description",
          "name": "Description",
          "valueType": "text",
          "description": "Brief description of the framework and its positioning"
        },
        {
          "id": "website",
          "name": "Website",
          "valueType": "link",
          "description": "Official website or landing page"
        },
        {
          "id": "repository",
          "name": "Repository",
          "valueType": "link",
          "description": "Primary source repository"
        },
        {
          "id": "creator",
          "name": "Creator / Org",
          "valueType": "text",
          "description": "Person, company, or organization behind the project"
        },
        {
          "id": "first-release",
          "name": "First Release",
          "valueType": {
            "type": "date",
            "direction": "ascending",
            "format": "year"
          },
          "description": "Year the project became publicly available"
        },
        {
          "id": "latest-release",
          "name": "Latest Release",
          "valueType": {
            "type": "date",
            "direction": "ascending",
            "format": "month-year"
          },
          "description": "Month and year of the most recent tagged release"
        },
        {
          "id": "license",
          "name": "License",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "mit", "value": "MIT", "color": "blue" },
              { "id": "apache-2", "value": "Apache 2.0", "color": "blue" },
              { "id": "gpl", "value": "GPL", "color": "red" },
              { "id": "bsd", "value": "BSD", "color": "cyan" },
              { "id": "mpl", "value": "MPL", "color": "orange" },
              { "id": "proprietary", "value": "Proprietary", "color": "gray" },
              { "id": "other", "value": "Other", "color": "gray" }
            ]
          },
          "description": "Distribution license"
        },
        {
          "id": "pricing-model",
          "name": "Pricing Model",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "free-oss", "value": "Free / OSS", "color": "green" },
              { "id": "freemium", "value": "Freemium", "color": "blue" },
              { "id": "paid-saas", "value": "Paid SaaS", "color": "purple" },
              { "id": "paid-self-hosted", "value": "Paid Self-Hosted", "color": "orange" }
            ]
          },
          "description": "Commercial model"
        },
        {
          "id": "open-source",
          "name": "Open Source",
          "valueType": "boolean",
          "description": "Whether the core methodology and tooling is OSI-open-source"
        }
      ]
    },
