        {
          "id": "opinionated",
          "name": "Opinionated",
          "valueType": "boolean",
          "description": "Whether the framework prescribes a strict workflow with limited deviation"
        },
        {
          "id": "ceremony-level",
          "name": "Ceremony Level",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "low", "value": "Low", "color": "green" },
              { "id": "medium", "value": "Medium", "color": "blue" },
              { "id": "high", "value": "High", "color": "orange" },
              { "id": "very-high", "value": "Very High", "color": "red" }
            ]
          },
          "description": "Process weight from lightweight rituals to heavy documentation and review gates"
        },
        {
          "id": "mechanization-level",
          "name": "Mechanization Level",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "low", "value": "Low", "color": "gray" },
              { "id": "medium", "value": "Medium", "color": "blue" },
              { "id": "high", "value": "High", "color": "green" },
              { "id": "very-high", "value": "Very High", "color": "purple" }
            ]
          },
          "description": "Automation degree from manual prompt copy-paste to managed end-to-end pipeline"
        }
      ]
    },
    {
      "id": "autonomy",
      "name": "Autonomy",
      "description": "How much human oversight is built in, and how autonomously the workflow can run",
      "expandedByDefault": false,
      "attributes": [
        {
          "id": "hitl-checkpoints",
          "name": "Human-in-the-Loop Checkpoints",
          "valueType": "boolean",
          "description": "Whether the workflow defines explicit review or approval points"
        },
        {
          "id": "approval-gates",
          "name": "Approval Gates per Phase",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "spec", "value": "Spec", "color": "blue" },
              { "id": "plan", "value": "Plan", "color": "blue" },
              { "id": "tasks", "value": "Tasks", "color": "green" },
              { "id": "implementation", "value": "Implementation", "color": "green" },
              { "id": "deploy", "value": "Deploy", "color": "red" }
            ]
          },
          "description": "Phases that require human approval in the default configuration"
        },
        {
          "id": "autonomous-e2e",
          "name": "Autonomous End-to-End Execution",
          "valueType": "boolean",
          "description": "Whether the tool can be configured to run idea to merged code without human intervention"
        },
        {
          "id": "autonomy-level",
          "name": "Autonomy Level",
          "valueType": {
            "type": "rating",
            "lower": 1,
            "upper": 5,
            "direction": "ascending",
            "symbols": {
              "empty": "○",
              "full": "●"
            }
          },
          "description": "1 = every step confirmed; 3 = phase-level approvals; 5 = fully autonomous"
        },
        {
          "id": "rollback-support",
          "name": "Rollback / Undo Support",
          "valueType": "boolean",
          "description": "Built-in mechanisms to revert generated artifacts or code changes"
        }
      ]
    },
