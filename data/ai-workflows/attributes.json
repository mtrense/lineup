        {
          "id": "methodology-style",
          "name": "Methodology Style",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "spec-centric", "value": "Spec-Centric", "color": "blue" },
              { "id": "process-centric", "value": "Process-Centric", "color": "purple" },
              { "id": "harness-centric", "value": "Harness-Centric", "color": "orange" },
              { "id": "strict-tdd", "value": "Strict TDD", "color": "red" },
              { "id": "bdd", "value": "BDD", "color": "red" },
              { "id": "agent-agile", "value": "Agent-Agile", "color": "green" },
              { "id": "multi-agent", "value": "Multi-Agent", "color": "cyan" },
              { "id": "plan-and-execute", "value": "Plan-and-Execute", "color": "blue" },
              { "id": "spec-driven", "value": "Spec-Driven", "color": "blue" }
