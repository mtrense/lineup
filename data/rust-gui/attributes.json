        {
          "id": "license",
          "name": "License",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "mit", "value": "MIT", "color": "blue" },
              { "id": "apache-2-0", "value": "Apache-2.0", "color": "blue" },
              { "id": "mpl-2-0", "value": "MPL-2.0", "color": "orange" },
