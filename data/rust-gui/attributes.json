              { "id": "wgpu", "value": "wgpu", "color": "orange" },
              { "id": "opengl", "value": "OpenGL", "color": "blue" },
              { "id": "vulkan", "value": "Vulkan", "color": "red" },
              { "id": "metal", "value": "Metal", "color": "gray" },
