              { "id": "gpl-3-0", "value": "GPL-3.0", "color": "red" }
            ]
          },
          "description": "Primary open-source license(s); note dual-licensing in a comment"
        },
        {
          "id": "repository",
          "name": "Repository",
          "valueType": "link",
          "description": "Primary source repository (GitHub, GitLab, sr.ht)"
        },
        {
          "id": "crates-io",
