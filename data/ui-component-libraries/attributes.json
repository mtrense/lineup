{
  "name": "UI Component Libraries",
  "description": "JavaScript/TypeScript component libraries for building web application interfaces",
  "groups": [
    {
      "id": "general",
      "name": "General Info",
      "description": "Basic information about the library",
      "expandedByDefault": true,
      "attributes": [
        {
          "id": "name",
          "name": "Name",
          "valueType": "text",
          "description": "Official name of the library"
        },
        {
          "id": "description",
          "name": "Description",
          "valueType": "text",
          "description": "One-line description of the library's main value proposition"
        },
        {
          "id": "website",
          "name": "Website",
          "valueType": "link",
          "description": "Official website or documentation site"
        },
        {
          "id": "repository",
          "name": "Repository",
          "valueType": "link",
          "description": "GitHub/GitLab repository URL"
        },
        {
          "id": "license",
          "name": "License",
          "valueType": "text",
          "description": "SPDX license identifier (MIT, Apache-2.0, Commercial, etc.)"
        },
        {
          "id": "active-maintenance",
          "name": "Active Maintenance",
          "valueType": "boolean",
          "description": "Regular commits/releases in last 6 months"
        },
        {
          "id": "initial-release",
          "name": "Initial Release",
          "valueType": {
            "type": "date",
            "direction": "ascending",
            "format": "year"
          },
          "description": "Year of first public release"
        },
        {
          "id": "latest-release",
          "name": "Latest Release",
          "valueType": {
            "type": "date",
            "direction": "ascending",
            "format": "full"
          },
          "description": "Date of most recent stable release"
        },
        {
          "id": "github-stars",
          "name": "GitHub Stars",
          "valueType": {
            "type": "integer",
            "direction": "ascending"
          },
          "description": "Current star count"
        }
      ]
    },
    {
