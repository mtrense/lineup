              { "id": "serializable", "value": "Serializable", "color": "blue" },
              { "id": "strong", "value": "Strong", "color": "green" },
              { "id": "causal", "value": "Causal", "color": "orange" },
              { "id": "read-your-writes", "value": "Read-Your-Writes", "color": "yellow" },
              { "id": "eventual", "value": "Eventual", "color": "red" }
            ]
          },
          "description": "Consistency guarantees provided"
        },
