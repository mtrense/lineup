          "name": "CAP Position",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "cp", "value": "CP", "color": "blue" },
              { "id": "ap", "value": "AP", "color": "green" },
              { "id": "tunable", "value": "Tunable", "color": "orange" }
            ]
          },
          "description": "Primary CAP theorem focus (Consistency vs Availability)"
        }
      ]
    },
    {
