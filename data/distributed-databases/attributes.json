          "id": "acid-transactions",
          "name": "ACID Transactions",
          "valueType": "boolean",
          "description": "Full ACID transaction support"
        },
        {
          "id": "transaction-scope",
          "name": "Transaction Scope",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "single-row", "value": "Single-Row", "color": "red" },
              { "id": "single-partition", "value": "Single-Partition", "color": "orange" },
              { "id": "cross-partition", "value": "Cross-Partition", "color": "green" },
              { "id": "global", "value": "Global", "color": "blue" }
            ]
          },
          "description": "Scope of transaction support"
        },
        {
          "id": "isolation-levels",
          "name": "Isolation Levels",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "read-uncommitted", "value": "Read Uncommitted", "color": "red" },
              { "id": "read-committed", "value": "Read Committed", "color": "orange" },
              { "id": "repeatable-read", "value": "Repeatable Read", "color": "yellow" },
              { "id": "snapshot", "value": "Snapshot", "color": "green" },
              { "id": "serializable", "value": "Serializable", "color": "blue" }
            ]
          },
          "description": "Supported transaction isolation levels"
        },
        {
          "id": "distributed-transactions",
          "name": "Distributed Transactions",
          "valueType": "boolean",
          "description": "Cross-node transaction coordination"
        }
