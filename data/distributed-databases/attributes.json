        {
          "id": "topology",
          "name": "Topology",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "leader-follower", "value": "Leader-Follower", "color": "blue" },
              { "id": "multi-leader", "value": "Multi-Leader", "color": "green" },
              { "id": "leaderless", "value": "Leaderless", "color": "orange" }
            ]
          },
          "description": "Cluster architecture style"
        },
        {
          "id": "sharding",
          "name": "Sharding",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "hash", "value": "Hash", "color": "blue" },
              { "id": "range", "value": "Range", "color": "green" },
              { "id": "geographic", "value": "Geographic", "color": "purple" },
              { "id": "automatic", "value": "Automatic", "color": "cyan" },
              { "id": "manual", "value": "Manual", "color": "orange" }
            ]
          },
          "description": "How data is partitioned across nodes"
