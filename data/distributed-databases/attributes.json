{
  "name": "Distributed Databases",
  "description": "Comparison of distributed database systems for scalable, fault-tolerant applications",
  "groups": [
    {
      "id": "overview",
      "name": "Overview",
      "description": "Basic information about the database",
      "expandedByDefault": true,
      "attributes": [
        {
          "id": "website",
          "name": "Website",
          "valueType": "link",
          "description": "Official project or product website"
        },
        {
          "id": "license",
          "name": "License",
          "valueType": "text",
          "description": "Software license (SPDX identifier preferred)"
        },
        {
          "id": "hosting-options",
          "name": "Hosting Options",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "self-hosted", "value": "Self-Hosted", "color": "blue" },
              { "id": "official-managed", "value": "Official Managed", "color": "green" },
              { "id": "third-party-managed", "value": "Third-Party Managed", "color": "orange" },
              { "id": "serverless", "value": "Serverless", "color": "purple" }
            ]
          },
          "description": "Available deployment models"
        },
        {
          "id": "initial-release",
          "name": "Initial Release",
          "valueType": {
            "type": "date",
            "direction": "ascending",
            "format": "year"
          },
          "description": "Year of first public release"
        },
        {
          "id": "primary-language",
          "name": "Primary Language",
          "valueType": "text",
          "description": "Main implementation language"
        },
        {
          "id": "data-model",
          "name": "Data Model",
          "valueType": {
            "type": "tags",
            "defaultColor": "gray",
            "tags": [
              { "id": "relational", "value": "Relational", "color": "blue" },
              { "id": "document", "value": "Document", "color": "green" },
              { "id": "key-value", "value": "Key-Value", "color": "orange" },
              { "id": "wide-column", "value": "Wide-Column", "color": "purple" },
              { "id": "graph", "value": "Graph", "color": "pink" },
              { "id": "time-series", "value": "Time-Series", "color": "cyan" }
            ]
          },
          "description": "Primary data model(s) supported"
        }
      ]
    },
    {
