        {
          "id": "manufacturer",
          "name": "Manufacturer",
          "valueType": "text",
          "description": "Company that designs and sells the board"
        },
        {
          "id": "model",
          "name": "Model",
          "valueType": "text",
          "description": "Official product name"
        },
        {
          "id": "release-date",
          "name": "Release Date",
          "valueType": {
            "type": "date",
            "direction": "ascending",
